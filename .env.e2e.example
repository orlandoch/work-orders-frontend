# Variables de entorno para E2E tests
# Copiar como .env.e2e en la raíz del proyecto

# URL del frontend Vite (default: http://localhost:5174)
E2E_BASE_URL=http://localhost:5174

# Credenciales de prueba (login real)
E2E_EMAIL=admin@wom.test
E2E_PASSWORD=password

# Token Sanctum (alternativa para saltar login)
E2E_AUTH_TOKEN=
